    "test": "vitest run"
  },
  "dependencies": {
    "@kortex/core": "workspace:*",
    "redis": "^4.7.0"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
