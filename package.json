{
  "name": "kortex",
  "version": "0.1.0-alpha",
  "private": true,
  "description": "Open-source AI Runtime Framework for building chatbot, agent, RAG, memory, and MCP applications with swappable LLM providers. Kortex is currently in alpha / developer preview.",
  "license": "MIT",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "vitest run && turbo run test",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,json,md}\"",
    "clean": "turbo run clean && rm -rf node_modules",
    "db:generate": "pnpm --filter @kortex/db db:generate",
    "db:migrate": "pnpm --filter @kortex/db db:migrate",
    "db:push": "pnpm --filter @kortex/db db:push",
    "db:studio": "pnpm --filter @kortex/db db:studio",
    "db:schema": "pnpm --filter @kortex/db db:bootstrap",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "demo": "pnpm --filter @kortex/docs-site dev",
    "docs": "pnpm --filter @kortex/docs-site dev"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "dotenv": "^16.4.7",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "tsup": "^8.3.5",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.0",
    "vitest": "^2.1.8"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=22"
  }
}
