# Kortex v1

AI_PROVIDER=openai
AI_MODEL=gpt-4o-mini

# Provider API keys
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=

# Local / HTTP providers
OLLAMA_BASE_URL=http://localhost:11434
LMSTUDIO_BASE_URL=http://localhost:1234
OPENCLAW_BASE_URL=http://localhost:18789
HERMES_BASE_URL=http://localhost:3000
OPENCLAW_TOKEN=
HERMES_TOKEN=

# Memory: postgres | redis | none
MEMORY_PROVIDER=none
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/kortex
REDIS_URL=redis://localhost:6379

# Vector: pgvector | qdrant | none
VECTOR_PROVIDER=none
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# Embeddings: openai | local | provider
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small

# MCP tools
MCP_ENABLED=false

# Debug
KORTEX_DEBUG=true
LOG_LEVEL=info

# Apply schema: pnpm db:migrate  OR  pnpm db:schema
