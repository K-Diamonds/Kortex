{
  "$schema": "./env.manifest.schema.json",
  "description": "Maps Kortex env keys to GitHub Actions secrets vs variables (production).",
  "sources": [".env.example", ".env.local"],
  "overrideFile": ".github/env.production.local",
  "productionDefaults": {
    "VERCEL_PROJECT_ID": "prj_WCfZqkYG0wkpTtwi90uJ8RFH96jg",
    "AI_PROVIDER": "openai",
    "AI_MODEL": "gpt-4o-mini",
    "MEMORY_PROVIDER": "none",
    "VECTOR_PROVIDER": "none",
    "EMBEDDING_PROVIDER": "openai",
    "EMBEDDING_MODEL": "text-embedding-3-small",
    "MCP_ENABLED": "false",
    "KORTEX_DEBUG": "false",
    "LOG_LEVEL": "info"
  },
  "localOnly": [],
  "secrets": [
    "OPENAI_API_KEY",
    "ANTHROPIC_API_KEY",
    "GEMINI_API_KEY",
    "OPENROUTER_API_KEY",
    "OPENCLAW_TOKEN",
    "HERMES_TOKEN",
    "DATABASE_URL",
    "REDIS_URL",
    "QDRANT_API_KEY"
  ],
  "deploySecrets": ["VERCEL_TOKEN", "VERCEL_ORG_ID", "VERCEL_PROJECT_ID"],
  "variables": [
    "AI_PROVIDER",
    "AI_MODEL",
    "MEMORY_PROVIDER",
    "VECTOR_PROVIDER",
    "EMBEDDING_PROVIDER",
    "EMBEDDING_MODEL",
    "OLLAMA_BASE_URL",
    "LMSTUDIO_BASE_URL",
    "OPENCLAW_BASE_URL",
    "HERMES_BASE_URL",
    "QDRANT_URL",
    "MCP_ENABLED",
    "KORTEX_DEBUG",
    "LOG_LEVEL"
  ],
  "vercel": {
    "deploySecrets": [
      "OPENAI_API_KEY",
      "ANTHROPIC_API_KEY",
      "GEMINI_API_KEY",
      "OPENROUTER_API_KEY",
      "OPENCLAW_TOKEN",
      "HERMES_TOKEN",
      "DATABASE_URL",
      "REDIS_URL",
      "QDRANT_API_KEY",
      "VERCEL_TOKEN",
      "VERCEL_ORG_ID",
      "VERCEL_PROJECT_ID"
    ],
    "deployVariables": [
      "AI_PROVIDER",
      "AI_MODEL",
      "MEMORY_PROVIDER",
      "VECTOR_PROVIDER",
      "EMBEDDING_PROVIDER",
      "EMBEDDING_MODEL",
      "OLLAMA_BASE_URL",
      "LMSTUDIO_BASE_URL",
      "OPENCLAW_BASE_URL",
      "HERMES_BASE_URL",
      "QDRANT_URL",
      "MCP_ENABLED",
      "KORTEX_DEBUG",
      "LOG_LEVEL"
    ]
  }
}
